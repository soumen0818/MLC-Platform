# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# Auth
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRY=7d
BCRYPT_SALT_ROUNDS=12

# Admin Bootstrap
ALLOW_ADMIN_REGISTER=true

# Email (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
FROM_EMAIL=noreply@mlcplatform.com

# Recharge Providers
RECHARGE_DEFAULT_PROVIDER=bharatpays
# Optional per-service overrides
# RECHARGE_DEFAULT_PROVIDER_MOBILE=setu
# RECHARGE_DEFAULT_PROVIDER_DTH=bharatpays

# BharatPays
BHARATPAYS_API_TOKEN=your-bharatpays-api-token
BHARATPAYS_USERNAME=your-bharatpays-username

# Setu
SETU_ENVIRONMENT=sandbox
SETU_API_BASE_URL=https://uat.setu.co/api/v2
SETU_AUTH_URL=https://uat.setu.co/api/v2/auth/token
SETU_PARTNER_ID=your-setu-partner-id
SETU_CLIENT_ID=your-setu-client-id
SETU_SECRET=your-setu-secret
SETU_WEBHOOK_API_KEY=shared-secret-from-setu

# Setu agent + payment settings
SETU_AGENT_ID=your-setu-agent-id
SETU_AGENT_CHANNEL=INT
SETU_AGENT_IP=203.0.113.10
SETU_AGENT_MAC=00:11:22:33:44:55
SETU_PAYMENT_MODE=Wallet
SETU_PAYMENT_ACCOUNT_INFO=your-npci-compatible-instrument-info
# Optional
# SETU_CUSTOMER_CONVENIENCE_FEE_PAISE=0
# SETU_AGENT_TERMINAL_ID=
# SETU_AGENT_IMEI=
# SETU_AGENT_OS=
# SETU_AGENT_APP=
# SETU_AGENT_MOBILE=
# SETU_AGENT_GEOCODE=
# SETU_AGENT_POSTAL_CODE=
# SETU_AGENT_IFSC=

# Setu biller mapping
# Use lowercase/slug keys for operator names. Add a `default` key when one biller should be used for all operators in that service.
# `customerParams.source` can be one of: mobileNumber, circle, operator, planId, amount, custom
# `flowType`: BILL_FETCH | BILL_VALIDATE | BILL_DIRECT
# `planMode`: NONE | CATALOG | PERSONALIZED
SETU_BILLER_CONFIG={"MOBILE":{"airtel":{"billerId":"AIRT00000NAT01","flowType":"BILL_FETCH","planMode":"CATALOG","planRequirement":"MANDATORY","customerParams":[{"name":"Mobile Number","source":"mobileNumber"},{"name":"Circle","source":"circle"},{"name":"Id","source":"planId"}]}},"DTH":{"tatasky":{"billerId":"TATA00000NAT01","flowType":"BILL_FETCH","planMode":"CATALOG","planRequirement":"OPTIONAL","customerParams":[{"name":"Subscriber Number","source":"mobileNumber"},{"name":"Id","source":"planId","required":false}]}}}

# File Upload
UPLOAD_SECRET=your-upload-secret
