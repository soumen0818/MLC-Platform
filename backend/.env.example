# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# Auth
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRY=7d
BCRYPT_SALT_ROUNDS=12

# Admin Bootstrap
ALLOW_ADMIN_REGISTER=true

# Email (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
FROM_EMAIL=noreply@mlcplatform.com

# Recharge API Provider
RECHARGE_API_URL=https://api.recharge-provider.com
RECHARGE_API_KEY=your-api-key
RECHARGE_WEBHOOK_SECRET=your-webhook-secret

# File Upload
UPLOAD_SECRET=your-upload-secret
